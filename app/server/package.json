  "description": "Portable local web UI for backing up blog pages as static HTML.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch src --exec \"node server.js\""
  },
  "dependencies": {
    "archiver": "7.0.1",
    "cheerio": "1.0.0",
    "express": "4.22.2",
    "playwright": "1.54.2"
  }
  ,
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
